KALSHI_API_KEY_ID=your-key-uuid
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key
PAPER_MODE=true

# Assets to trade (subset of: btc, eth, sol, xrp, doge)
ASSETS=btc,eth,sol,xrp,doge

# --- Daily summary email (sent by scripts/watchdog.py summary) ---
# For Gmail/Google Workspace use an App Password (not your login password):
#   myaccount.google.com -> Security -> 2-Step Verification -> App passwords
EMAIL_TO=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_char_app_password

# --- Research data collection (data/spot_history.db) ---
# Raw microstructure retained for offline model iteration. Every high-volume
# table is retention-bounded so the DB plateaus in size and can run for weeks.
# Defaults are sized for ~5 assets on a small box.
ORDERBOOK_DAYS=45            # how long to keep order-book depth snapshots
TRADES_DAYS=45              # how long to keep the trade tape
ORDERBOOK_RAMP_SEC=2        # min seconds between depth snapshots in the final 60s
TRADES_POLL_SEC=12          # min seconds between trade-tape polls per asset/window
SPOT_HISTORY_DAYS=180       # raw 1-minute spot bars retention

# --- strategy / risk (see bot/config.py) ---
MARGIN=0.03
MIN_LS_PRICE=0.02
MAX_LS_PRICE=0.20
CONTRACTS_PER_QUOTE=10
MAX_RISK_PER_WINDOW=10
MAX_DAILY_LOSS=100
# Skip quotes when the favorite-side edge (model P - cost) >= MAX_EDGE (dollars).
# A very wide inferred edge usually means a stale model rather than opportunity.
MAX_EDGE=0.05

# --- requote-policy A/B harness (bot/ab.py) ---
# When on, each window is split 3 ways by a stable hash to compare requote
# policies (control vs sticky vs fast). Off by default -> all windows run control.
AB_TEST=false
AB_REPLACE_THRESHOLD=0.04        # B sticky: min |price move| before a replace
AB_MIN_IN_BOOK_SEC=12            # B sticky: min seconds resting before a replace
AB_FAST_REPLACE_THRESHOLD=0.01   # C fast: replace on a one-cent move
AB_FAST_MIN_IN_BOOK_SEC=0        # C fast: no resting cooldown
AB_EXPOSURE_SEC=4                # tape print within Ns after a cancel = exposure
